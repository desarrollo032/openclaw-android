<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/application_name"
            android:textColor="#FFFFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Version -->
        <TextView
            android:id="@+id/about_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- Termux Credit Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_credits_title"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/about_termux_credit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_termux_credit"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="12dp" />

        <android.widget.Button
            android:id="@+id/about_btn_termux_github"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_btn_termux_github"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF388E3C"
            android:layout_marginTop="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- License Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_license_title"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_license_text"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- Project Link Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_project_title"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/about_project_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_project_text"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="12dp" />

        <android.widget.Button
            android:id="@+id/about_btn_project_github"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_btn_project_github"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF388E3C"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
